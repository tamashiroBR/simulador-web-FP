Options -Indexes
RewriteEngine On

# Sem RewriteBase: o Apache resolve o caminho relativo ao diretório onde
# este .htaccess está localizado, funcionando em qualquer subdiretório
# de instalação sem necessidade de alteração.
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
